# Cloudflare Worker URL for encrypted backup storage.
# Copy this file to .env.local and fill in the value.
# Deploy the worker: cd cloudflare-worker && npm run deploy
# Local dev: cd cloudflare-worker && npm run dev, then use http://localhost:8787
# Cloud backup is disabled when empty.
VITE_BACKUP_API_URL=

# Cloudflare Turnstile site key (protects restore and first backup).
# Local dev: omit or use test key 1x00000000000000000000AA (auto-fallback in dev)
# Production: REQUIRED - get from Cloudflare Dashboard > Turnstile for librebudget.app
VITE_TURNSTILE_SITE_KEY=
