# Production environment variables
# Copy to .env.production.local and fill in your values.
# Used when running: npm run build

# Cloudflare Worker URL for encrypted backup storage
VITE_BACKUP_API_URL=

# Cloudflare Turnstile site key (REQUIRED for production)
# Get from Cloudflare Dashboard > Turnstile > Add site > librebudget.app
# Do NOT use the test key in production
VITE_TURNSTILE_SITE_KEY=
